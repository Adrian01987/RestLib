{
  "ConnectionStrings": {
    "Ecommerce": "Data Source=restlib-ecommerce.db"
  },
  "RestLibSample": {
    "UseMigrations": false,
    "Auth": {
      "Issuer": "RestLib.Sample.Ecommerce",
      "Audience": "RestLib.Sample.Ecommerce",
      "SigningKey": "sample-only-restlib-ecommerce-signing-key-change-before-production",
      "BootstrapKey": "dev-bootstrap-key",
      "TokenLifetimeMinutes": 60
    },
    "Payments": {
      "FakeExternalClient": {
        "LatencyMilliseconds": 150,
        "FailureRate": 0,
        "FailureErrorCode": "payment_declined"
      }
    }
  },
  "RestLib": {
    "Resources": {
      "Countries": {
        "Name": "reference-countries",
        "Route": "/api/reference/countries",
        "KeyProperty": "Code",
        "AllowAnonymousAll": true,
        "Operations": {
          "Include": ["GetAll", "GetById"]
        },
        "Filtering": ["Region", "CurrencyCode", "IsShippingEnabled"],
        "FilteringOperators": {
          "Code": ["string"],
          "Name": ["string"]
        },
        "Sorting": ["Code", "Name", "Region"],
        "DefaultSort": "name:asc",
        "FieldSelection": ["Code", "Name", "Region", "CurrencyCode", "IsShippingEnabled"],
        "RateLimiting": {
          "Default": "storefront-read"
        },
        "OpenApi": {
          "Tag": "Reference Data",
          "TagDescription": "Read-only ecommerce reference data declared from appsettings.",
          "Summaries": {
            "GetAll": "List countries",
            "GetById": "Get country by code"
          },
          "Descriptions": {
            "GetAll": "Returns supported country reference data configured through appsettings.",
            "GetById": "Returns one country reference row by ISO alpha-2 code."
          }
        }
      },
      "PaymentMethods": {
        "Name": "reference-payment-methods",
        "Route": "/api/reference/payment-methods",
        "KeyProperty": "Key",
        "AllowAnonymousAll": true,
        "Operations": {
          "Include": ["GetAll", "GetById"]
        },
        "Filtering": ["IsEnabled"],
        "FilteringOperators": {
          "Key": ["string"],
          "DisplayName": ["string"]
        },
        "Sorting": ["SortOrder", "DisplayName", "Key"],
        "DefaultSort": "sort_order:asc",
        "FieldSelection": ["Key", "DisplayName", "Description", "IsEnabled", "SortOrder"],
        "RateLimiting": {
          "Default": "storefront-read"
        },
        "OpenApi": {
          "Tag": "Reference Data",
          "Summaries": {
            "GetAll": "List payment methods",
            "GetById": "Get payment method by key"
          },
          "Descriptions": {
            "GetAll": "Returns supported checkout payment methods configured through appsettings.",
            "GetById": "Returns one payment method reference row by key."
          }
        }
      }
    }
  }
}
