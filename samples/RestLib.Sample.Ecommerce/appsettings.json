{
  "ConnectionStrings": {
    "Ecommerce": "Data Source=restlib-ecommerce.db"
  },
  "RestLibSample": {
    "UseMigrations": false,
    "Auth": {
      "Issuer": "RestLib.Sample.Ecommerce",
      "Audience": "RestLib.Sample.Ecommerce",
      "SigningKey": "sample-only-restlib-ecommerce-signing-key-change-before-production",
      "BootstrapKey": "dev-bootstrap-key",
      "TokenLifetimeMinutes": 60
    },
    "Payments": {
      "FakeExternalClient": {
        "LatencyMilliseconds": 150,
        "FailureRate": 0,
        "FailureErrorCode": "payment_declined"
      }
    }
  }
}
