{
  "$schema": "../../../schemas/restlib-resource.schema.json",
  "EntityType": "RestLib.Sample.Ecommerce.Models.Address, RestLib.Sample.Ecommerce",
  "Name": "storefront-addresses",
  "Route": "/api/storefront/addresses",
  "Policies": {
    "GetAll": ["Customer"],
    "GetById": ["Customer"],
    "Create": ["Customer"],
    "Update": ["Customer"],
    "Patch": ["Customer"],
    "Delete": ["Customer"]
  },
  "Filtering": ["IsPrimary", "CountryCode"],
  "FilteringOperators": {
    "City": ["string"],
    "PostalCode": ["string"]
  },
  "Sorting": ["CreatedAt", "City", "IsPrimary"],
  "DefaultSort": "created_at:desc",
  "FieldSelection": ["Id", "CustomerId", "Line1", "Line2", "City", "Region", "PostalCode", "CountryCode", "IsPrimary", "CreatedAt", "UpdatedAt"],
  "Hooks": {
    "BeforePersist": {
      "ByOperation": {
        "Create": ["EnsureSinglePrimary"],
        "Update": ["EnsureSinglePrimary"]
      }
    },
    "AfterPersist": {
      "ByOperation": {
        "Patch": ["EnsureSinglePrimary"]
      }
    }
  },
  "OpenApi": {
    "Tag": "Storefront Profile",
    "TagDescription": "Customer-owned profile resources scoped by EF Core query filters.",
    "Summaries": {
      "GetAll": "List my addresses",
      "GetById": "Get my address by id",
      "Create": "Create my address",
      "Update": "Replace my address",
      "Patch": "Patch my address",
      "Delete": "Delete my address"
    },
    "Descriptions": {
      "Create": "Creates an address owned by the authenticated customer. The primary hook demotes other primary addresses."
    }
  },
  "Validation": {
    "Line1": {
      "Required": true,
      "Length": {
        "Max": 200
      }
    },
    "City": {
      "Required": true,
      "Length": {
        "Max": 100
      }
    },
    "Region": {
      "Length": {
        "Max": 100
      }
    },
    "PostalCode": {
      "Required": true,
      "Length": {
        "Max": 30
      }
    },
    "CountryCode": {
      "Required": true,
      "Pattern": "^[A-Z]{2}$",
      "Length": {
        "Min": 2,
        "Max": 2
      }
    }
  }
}
