  "Name": "admin-support-tickets",
  "Route": "/api/admin/support/tickets",
  "Operations": {
    "Include": ["GetAll", "GetById"]
  },
  "Policies": {
    "GetAll": ["Admin"],
    "GetById": ["Admin"]
