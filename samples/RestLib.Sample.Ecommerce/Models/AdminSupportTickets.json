  "RateLimiting": {
    "Default": "storefront-read"
  },
  "OpenApi": {
    "Tag": "Admin Support",
    "TagDescription": "Admin support ticket read surface.",
    "Summaries": {
      "GetAll": "List support tickets",
      "GetById": "Get support ticket by id"
    },
    "Descriptions": {
